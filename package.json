{
  "name": "@heyai-rules/pilo-masterkit",
  "version": "1.2.3",
  "description": "Scaffold and install PILO ruleset into a project.",
  "keywords": [
    "create",
    "cli",
    "ruleset",
    "agent"
  ],
  "homepage": "https://github.com/Arter2507/pilo-masterkit#readme",
  "bugs": {
    "url": "https://github.com/Arter2507/pilo-masterkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arter2507/pilo-masterkit.git"
  },
  "license": "Apache-2.0",
  "author": "Arter",
  "type": "commonjs",
  "main": "src/bin/cli.js",
  "bin": {
    "create-pilo-masterkit": "src/bin/cli.js"
  },
  "files": [
    "src",
    ".agent",
    "README.md",
    "RELEASE.md",
    "scripts/release-check.js"
  ],
  "scripts": {
    "check": "node --check src/bin/cli.js",
    "pack:dry": "npm pack --dry-run",
    "release:check": "node scripts/release-check.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "semantic-release": "^24.2.3"
  },
  "release": {
    "branches": [
      "main",
      "next"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "fs-extra": "^11.3.4",
    "picocolors": "^1.1.1"
  }
}
